{
  "name": "vs-point/moneys3",
  "version": "1.0.0",
  "type": "library",
  "description": "A strictly typed PHP library for communication with the Money S3 accounting software via its GraphQL API.",
  "keywords": ["money", "moneys3", "seyfor", "graphql", "api", "accounting", "ucetnictvi"],
  "license": "MIT",
  "authors": [
    {
      "name": "Vít Steklý",
      "email": "stekly.vit@vs-point.cz"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/serializer": "^6.4|^7.0|^8.0",
    "symfony/property-access": "^6.4|^7.0|^8.0",
    "brick/math": "^0.12|^0.13",
    "brick/date-time": "^0.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "symplify/easy-coding-standard": "^12.0",
    "symfony/http-kernel": "^6.4|^7.0|^8.0",
    "symfony/dependency-injection": "^6.4|^7.0|^8.0",
    "symfony/config": "^6.4|^7.0|^8.0"
  },
  "suggest": {
    "symfony/http-kernel": "To use the bundled Symfony integration (MoneyS3Bundle)."
  },
  "autoload": {
    "psr-4": {
      "VsPoint\\MoneyS3\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VsPoint\\MoneyS3\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
